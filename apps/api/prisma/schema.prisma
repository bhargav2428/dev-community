  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  completedAt     DateTime?
  
  host            User            @relation("CoffeeChatHost", fields: [hostId], references: [id])
  guest           User?           @relation("CoffeeChatGuest", fields: [guestId], references: [id])
