  createdAt       DateTime        @default(now())
  
  mentor          MentorProfile   @relation(fields: [mentorId], references: [id])
  reviewer        User            @relation("MentorReviews", fields: [reviewerId], references: [id])
  
  @@unique([mentorId, reviewerId])
}

enum MentorshipStatus {
  PENDING
  ACTIVE
  PAUSED
  COMPLETED
  DECLINED
}

enum SessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ============================================
// UNIQUE FEATURES - Build in Public
// ============================================

model BuildInPublic {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  userId          String          @db.ObjectId
  projectId       String?         @db.ObjectId
  
  title           String
  content         String
  
  // Update type
  type            BuildUpdateType
  
  // Metrics (optional)
  revenue         Float?
  users           Int?
  mrr             Float?
  customMetrics   Json?
  
  // Media
  images          String[]
  links           String[]
  
  // Engagement
  likesCount      Int             @default(0)
  commentsCount   Int             @default(0)
  sharesCount     Int             @default(0)
  
  isPublic        Boolean         @default(true)
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  user            User            @relation(fields: [userId], references: [id])
  project         Project?        @relation(fields: [projectId], references: [id])
  
  @@index([userId])
  @@index([projectId])
  @@index([type])
  @@index([createdAt])
}

enum BuildUpdateType {
  MILESTONE
  REVENUE_UPDATE
  USER_UPDATE
  FEATURE_LAUNCH
  LESSON_LEARNED
  WEEKLY_UPDATE
  MONTHLY_RECAP
  PIVOT
  FAILURE
  WIN
}

// ============================================
// UNIQUE FEATURES - Developer Wrapped
// ============================================

model DeveloperWrapped {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  userId          String          @db.ObjectId
  year            Int
  
  // Activity stats
  postsCount      Int             @default(0)
  commentsCount   Int             @default(0)
  likesGiven      Int             @default(0)
  likesReceived   Int             @default(0)
  
  // Collaboration
  projectsJoined  Int             @default(0)
  projectsCreated Int             @default(0)
  coffeeChats     Int             @default(0)
  pairSessions    Int             @default(0)
  
  // Growth
  followersGained Int             @default(0)
  followingAdded  Int             @default(0)
  connectionsMode Int             @default(0)
  
  // Skills
  skillsLearned   String[]
  topSkills       String[]
  skillTreesCompleted Int         @default(0)
  
  // Achievements
  badgesEarned    Int             @default(0)
  xpGained        Int             @default(0)
  levelsGained    Int             @default(0)
  
  // Contributions
  bountiesCompleted Int           @default(0)
  bountyEarnings  Float           @default(0)
  
  // Top content
  topPostId       String?         @db.ObjectId
  topProjectId    String?         @db.ObjectId
  
  // Fun stats
  mostActiveDay   String?
  mostActiveHour  Int?
  longestStreak   Int             @default(0)
  totalDaysActive Int             @default(0)
  
  // Personality
  developerType   String?         // "Night Owl", "Early Bird", etc.
  topTags         String[]
  
  generatedAt     DateTime        @default(now())
  isPublic        Boolean         @default(true)
  shareUrl        String?
  
  user            User            @relation(fields: [userId], references: [id])
  
  @@unique([userId, year])
  @@index([userId])
  @@index([year])
}


