// DevConnect - Developer Social Network
// MongoDB Database Schema with Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  email             String    @unique
  username          String    @unique
  passwordHash      String?
  firstName         String?
  lastName          String?
  displayName       String?
  
  // Profile
  avatar            String?
  coverImage        String?
  bio               String?
  headline          String?
  location          String?
  website           String?
  githubUrl         String?
  linkedinUrl       String?
  twitterUrl        String?
  
  // Status
  isVerified        Boolean   @default(false)
  isOnline          Boolean   @default(false)
  lastSeenAt        DateTime?
  emailVerified     Boolean   @default(false)
  twoFactorEnabled  Boolean   @default(false)
  twoFactorSecret   String?
  
  // Settings
  isAvailableForHire Boolean  @default(false)
  isOpenToCollab    Boolean   @default(true)
  profileVisibility ProfileVisibility @default(PUBLIC)
  
  // Reputation System
  reputationScore   Int       @default(0)
  level             Int       @default(1)
  xp                Int       @default(0)
  
  // Role & Permissions
  role              UserRole  @default(USER)
  
  // Timestamps
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?
  
  // Relations
  profile           Profile?
  oauthAccounts     OAuthAccount[]
  sessions          Session[]
  skills            UserSkill[]
  experiences       Experience[]
  education         Education[]
  projects          ProjectMember[]
  ownedProjects     Project[]       @relation("ProjectOwner")
  posts             Post[]
  comments          Comment[]
  likes             Like[]
  bookmarks         Bookmark[]
  followers         Follow[]        @relation("Following")
  following         Follow[]        @relation("Follower")
  sentMessages      Message[]       @relation("MessageSender")
  receivedMessages  Message[]       @relation("MessageReceiver")
  conversations     ConversationMember[]
  notifications     Notification[]  @relation("UserNotifications")
  sentNotifications Notification[]  @relation("SentNotifications")
  ideas             StartupIdea[]
  ideaVotes         IdeaVote[]
  teamInvitations   TeamInvitation[]
  badges            UserBadge[]
  contributions     Contribution[]
  hackathonParticipations HackathonParticipant[]
  jobApplications   JobApplication[]
  postedJobs        Job[]
  activities        Activity[]
  reports           Report[]        @relation("Reporter")
  reportedContent   Report[]        @relation("ReportedUser")
  adminActions      AdminLog[]      @relation("AdminActions")
  blockedUsers      Block[]         @relation("Blocker")
  blockedBy         Block[]         @relation("Blocked")
  refreshTokens     RefreshToken[]
  
  // Unique Features Relations
  coffeeChatsHosted  CoffeeChat[]    @relation("CoffeeChatHost")
  coffeeChatsJoined  CoffeeChat[]    @relation("CoffeeChatGuest")
  bountiesCreated    CodeBounty[]    @relation("BountyCreator")
  bountySubmissions  BountySubmission[] @relation("BountySubmitter")
  skillTrees         UserSkillTree[]
  pairSessionsHosted PairSession[]   @relation("PairSessionHost")
  pairSessionsJoined PairSession[]   @relation("PairSessionPartner")
  interviewsGiven    MockInterview[] @relation("MockInterviewer")
  interviewsTaken    MockInterview[] @relation("MockInterviewee")
  mentorProfile      MentorProfile?
  mentorships        MentorRelationship[]
  mentorSessions     MentorSession[] @relation("MenteeSessions")
  mentorReviews      MentorReview[]  @relation("MentorReviews")
  buildUpdates       BuildInPublic[]
  wrappedStats       DeveloperWrapped[]
}

model Profile {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  userId            String    @unique @db.ObjectId
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Extended Profile
  yearsOfExperience Int?
  currentRole       String?
  company           String?
  resumeUrl         String?
  portfolioUrl      String?
  
  // Preferences
  timezone          String?
  preferredLanguage String?   @default("en")
  
  // GitHub Stats (cached)
  githubUsername    String?
  githubRepos       Int       @default(0)
  githubStars       Int       @default(0)
  githubContributions Int     @default(0)
  githubLastSynced  DateTime?
  
  // Analytics
  profileViews      Int       @default(0)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model OAuthAccount {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  userId            String    @db.ObjectId
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  provider          OAuthProvider
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  tokenType         String?
  scope             String?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([provider, providerAccountId])
}

model Session {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  userId        String    @db.ObjectId
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  token         String    @unique
  userAgent     String?
  ipAddress     String?
  expiresAt     DateTime
  
  createdAt     DateTime  @default(now())
}

model RefreshToken {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  userId        String    @db.ObjectId
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  token         String    @unique
  expiresAt     DateTime
  isRevoked     Boolean   @default(false)
  
  createdAt     DateTime  @default(now())
}

model VerificationToken {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  email         String
  token         String    @unique
  type          TokenType
  expiresAt     DateTime
  
  createdAt     DateTime  @default(now())
}

// ============================================
// SKILLS & EXPERTISE
// ============================================

model Skill {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  name          String      @unique
  slug          String      @unique
  category      SkillCategory
  icon          String?
  color         String?
  description   String?
  
  users         UserSkill[]
  projects      ProjectSkill[]
  jobs          JobSkill[]
  ideas         IdeaSkill[]
  
  createdAt     DateTime    @default(now())
}

model UserSkill {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  userId        String    @db.ObjectId
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId       String    @db.ObjectId
  skill         Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)
  
  level         SkillLevel @default(INTERMEDIATE)
  yearsOfExp    Int?
  isPrimary     Boolean   @default(false)
  endorsements  Int       @default(0)
  
  createdAt     DateTime  @default(now())

  @@unique([userId, skillId])
}

// ============================================
// EXPERIENCE & EDUCATION
// ============================================

model Experience {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  userId        String    @db.ObjectId
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title         String
  company       String
  companyLogo   String?
  location      String?
  type          EmploymentType
  description   String?
  
  startDate     DateTime
  endDate       DateTime?
  isCurrent     Boolean   @default(false)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Education {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  userId        String    @db.ObjectId
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  institution   String
  degree        String
  field         String?
  logo          String?
  description   String?
  
  startDate     DateTime
  endDate       DateTime?
  isCurrent     Boolean   @default(false)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ============================================
// PROJECTS & COLLABORATION
// ============================================

model Project {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  ownerId         String    @db.ObjectId
  owner           User      @relation("ProjectOwner", fields: [ownerId], references: [id])
  
  name            String
  slug            String    @unique
  description     String?
  longDescription String?
  
  // Media
  logo            String?
  coverImage      String?
  screenshots     String[]
  
  // Links
  website         String?
  githubUrl       String?
  demoUrl         String?
  
  // Status
  status          ProjectStatus @default(ACTIVE)
  visibility      ProjectVisibility @default(PUBLIC)
  stage           ProjectStage @default(IDEA)
  
  // Metrics
  stars           Int       @default(0)
  forks           Int       @default(0)
  views           Int       @default(0)
  
  // Settings
  isOpenSource    Boolean   @default(false)
  isRecruiting    Boolean   @default(false)
  isFeatured      Boolean   @default(false)
  maxTeamSize     Int?
  
  // Timestamps
  launchedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  
  // Relations
  members         ProjectMember[]
  skills          ProjectSkill[]
  tasks           Task[]
  milestones      Milestone[]
  posts           Post[]    @relation("ProjectPosts")
  channels        Channel[]
  invitations     ProjectInvitation[]
  contributions   Contribution[]
  buildUpdates    BuildInPublic[]

  // Project starring
  projectStars    ProjectStar[]
}

// PROJECT STARRING
model ProjectStar {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  projectId String   @db.ObjectId
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
  @@index([projectId])
  @@index([userId])
}

model ProjectMember {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  projectId     String    @db.ObjectId
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId        String    @db.ObjectId
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  role          ProjectRole @default(MEMBER)
  title         String?
  joinedAt      DateTime  @default(now())
  
  @@unique([projectId, userId])
}

model ProjectSkill {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  projectId   String    @db.ObjectId
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  skillId     String    @db.ObjectId
  skill       Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)
  
  isRequired  Boolean   @default(false)
  
  @@unique([projectId, skillId])
}

model ProjectInvitation {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  projectId     String    @db.ObjectId
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  email         String?
  userId        String?
  role          ProjectRole @default(MEMBER)
  message       String?
  token         String    @unique
  
  status        InvitationStatus @default(PENDING)
  expiresAt     DateTime
  
  createdAt     DateTime  @default(now())
}

// ============================================
// TASKS & MILESTONES
// ============================================

model Task {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  projectId     String    @db.ObjectId
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  title         String
  description   String?
  status        TaskStatus @default(TODO)
  priority      TaskPriority @default(MEDIUM)
  
  assigneeId    String?
  reporterId    String?
  
  dueDate       DateTime?
  completedAt   DateTime?
  
  labels        String[]
  order         Int       @default(0)
  
  milestoneId   String?   @db.ObjectId
  milestone     Milestone? @relation(fields: [milestoneId], references: [id])
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Milestone {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  projectId     String    @db.ObjectId
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  title         String
  description   String?
  dueDate       DateTime?
  completedAt   DateTime?
  
  tasks         Task[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ============================================
// SOCIAL FEED
// ============================================

model Post {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  authorId      String    @db.ObjectId
  author        User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  content       String
  type          PostType  @default(TEXT)
  
  // Media
  images        String[]
  video         String?
  linkPreview   Json?
  
  // Relations
  projectId     String?   @db.ObjectId
  project       Project?  @relation("ProjectPosts", fields: [projectId], references: [id])
  
  // Engagement
  likesCount    Int       @default(0)
  commentsCount Int       @default(0)
  sharesCount   Int       @default(0)
  viewsCount    Int       @default(0)
  
  // Settings
  visibility    PostVisibility @default(PUBLIC)
  isPinned      Boolean   @default(false)
  isFeatured    Boolean   @default(false)
  
  // Moderation
  isApproved    Boolean   @default(true)
  moderatedAt   DateTime?
  
  // Timestamps
  publishedAt   DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  
  // Relations
  comments      Comment[]
  likes         Like[]
  bookmarks     Bookmark[]
  tags          PostTag[]
  shares        Share[]
}

model Comment {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  postId        String    @db.ObjectId
  post          Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId      String    @db.ObjectId
  author        User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  content       String
  
  // Nested comments
  parentId      String?   @db.ObjectId
  parent        Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies       Comment[] @relation("CommentReplies")
  
  likesCount    Int       @default(0)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
}

model Like {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  userId        String    @db.ObjectId
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId        String    @db.ObjectId
  post          Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime  @default(now())

  @@unique([userId, postId])
}

model Bookmark {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  userId        String    @db.ObjectId
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId        String    @db.ObjectId
  post          Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime  @default(now())

  @@unique([userId, postId])
}

model Share {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  postId        String    @db.ObjectId
  post          Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId        String
  
  platform      String?
  
  createdAt     DateTime  @default(now())
}

model Tag {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String    @unique
  slug          String    @unique
  description   String?
  postsCount    Int       @default(0)
  
  posts         PostTag[]
  
  createdAt     DateTime  @default(now())
}

model PostTag {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  postId      String    @db.ObjectId
  post        Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  tagId       String    @db.ObjectId
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  @@unique([postId, tagId])
}

// ============================================
// SOCIAL CONNECTIONS
// ============================================

model Follow {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  followerId    String    @db.ObjectId
  follower      User      @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followingId   String    @db.ObjectId
  following     User      @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime  @default(now())

  @@unique([followerId, followingId])
}

model Block {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  blockerId     String    @db.ObjectId
  blocker       User      @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId     String    @db.ObjectId
  blocked       User      @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime  @default(now())

  @@unique([blockerId, blockedId])
}

// ============================================
// MESSAGING
// ============================================

model Conversation {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  type          ConversationType @default(DIRECT)
  name          String?
  avatar        String?
  
  lastMessageAt DateTime?
  
  members       ConversationMember[]
  messages      Message[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ConversationMember {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  conversationId  String    @db.ObjectId
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId          String    @db.ObjectId
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  role            ConversationRole @default(MEMBER)
  lastReadAt      DateTime?
  isMuted         Boolean   @default(false)
  
  joinedAt        DateTime  @default(now())

  @@unique([conversationId, userId])
}

model Message {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  conversationId  String    @db.ObjectId
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId        String    @db.ObjectId
  sender          User      @relation("MessageSender", fields: [senderId], references: [id])
  
  content         String
  type            MessageType @default(TEXT)
  
  // Media
  attachments     Json?
  
  // Reply
  replyToId       String?
  
  // Status
  isEdited        Boolean   @default(false)
  isDeleted       Boolean   @default(false)
  
  // For DMs
  receiverId      String?   @db.ObjectId
  receiver        User?     @relation("MessageReceiver", fields: [receiverId], references: [id])
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ============================================
// PROJECT CHANNELS (Team Chat)
// ============================================

model Channel {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  projectId     String    @db.ObjectId
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  name          String
  description   String?
  type          ChannelType @default(TEXT)
  isPrivate     Boolean   @default(false)
  
  messages      ChannelMessage[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ChannelMessage {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  channelId     String    @db.ObjectId
  channel       Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId        String
  
  content       String
  attachments   Json?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  userId        String    @db.ObjectId
  user          User      @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  
  senderId      String?   @db.ObjectId
  sender        User?     @relation("SentNotifications", fields: [senderId], references: [id], onDelete: SetNull)
  
  type          NotificationType
  title         String
  message       String
  
  // Reference to related entity
  entityType    String?
  entityId      String?
  
  // Action URL
  actionUrl     String?
  
  // Status
  isRead        Boolean   @default(false)
  readAt        DateTime?
  
  createdAt     DateTime  @default(now())
}

// ============================================
// STARTUP IDEAS MARKETPLACE
// ============================================

model StartupIdea {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  authorId        String    @db.ObjectId
  author          User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  title           String
  slug            String    @unique
  
  // Problem & Solution
  problem         String
  solution        String
  targetMarket    String?
  
  // Details
  description     String?
  businessModel   String?
  competitors     String?
  
  // Media
  coverImage      String?
  pitchDeck       String?
  
  // Status
  stage           IdeaStage @default(CONCEPT)
  status          IdeaStatus @default(OPEN)
  
  // Engagement
  votesCount      Int       @default(0)
  commentsCount   Int       @default(0)
  viewsCount      Int       @default(0)
  
  // Settings
  isLookingForCofounder Boolean @default(true)
  equity          String?
  investment      String?
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  
  // Relations
  skills          IdeaSkill[]
  roles           IdeaRole[]
  votes           IdeaVote[]
  team            TeamInvitation[]
}

model IdeaSkill {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  ideaId      String      @db.ObjectId
  idea        StartupIdea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  skillId     String      @db.ObjectId
  skill       Skill       @relation(fields: [skillId], references: [id], onDelete: Cascade)
  
  @@unique([ideaId, skillId])
}

model IdeaRole {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  ideaId        String      @db.ObjectId
  idea          StartupIdea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  
  title         String
  description   String?
  responsibilities String?
  requirements  String?
  
  isFilled      Boolean     @default(false)
  
  createdAt     DateTime    @default(now())
}

model IdeaVote {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  ideaId      String      @db.ObjectId
  idea        StartupIdea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  userId      String      @db.ObjectId
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  value       Int
  
  createdAt   DateTime    @default(now())

  @@unique([ideaId, userId])
}

model TeamInvitation {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  ideaId        String      @db.ObjectId
  idea          StartupIdea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  userId        String      @db.ObjectId
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  role          String?
  message       String?
  
  status        InvitationStatus @default(PENDING)
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

// ============================================
// HACKATHONS & EVENTS
// ============================================

model Hackathon {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  organizerId     String
  
  name            String
  slug            String    @unique
  description     String
  
  // Media
  logo            String?
  coverImage      String?
  
  // Details
  theme           String?
  prizes          Json?
  rules           String?
  judgingCriteria String?
  
  // Links
  website         String?
  
  // Dates
  startDate       DateTime
  endDate         DateTime
  registrationDeadline DateTime?
  
  // Location
  isOnline        Boolean   @default(true)
  location        String?
  
  // Status
  status          HackathonStatus @default(UPCOMING)
