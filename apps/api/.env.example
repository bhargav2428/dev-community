# DevConnect API Environment Variables

# ====================
# REQUIRED SETTINGS
# ====================

# App
NODE_ENV=production
PORT=4000
API_URL=https://your-api.railway.app
CLIENT_URL=https://your-app.vercel.app

# Database (MongoDB Atlas)
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/devconnect"

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-characters
JWT_REFRESH_EXPIRES_IN=7d

# Session
SESSION_SECRET=your-session-secret-min-32-characters

# ====================
# FEATURE FLAGS
# ====================
# Set to 'true' to enable optional features

ENABLE_REDIS=false
ENABLE_OAUTH=false
ENABLE_EMAIL=false
ENABLE_S3=false
ENABLE_OPENAI=false
ENABLE_ELASTICSEARCH=false

# ====================
# OPTIONAL: Redis
# ====================
# Required if ENABLE_REDIS=true
REDIS_URL="redis://default:password@host:port"

# ====================
# OPTIONAL: OAuth Providers
# ====================
# Required if ENABLE_OAUTH=true

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://your-api.railway.app/api/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=https://your-api.railway.app/api/auth/github/callback

# ====================
# OPTIONAL: Email (SMTP)
# ====================
# Required if ENABLE_EMAIL=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="DevConnect <noreply@devconnect.io>"

# ====================
# OPTIONAL: AWS S3
# ====================
# Required if ENABLE_S3=true
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=devconnect-uploads

# ====================
# OPTIONAL: OpenAI
# ====================
# Required if ENABLE_OPENAI=true
OPENAI_API_KEY=your-openai-api-key

# ====================
# OPTIONAL: Elasticsearch
# ====================
# Required if ENABLE_ELASTICSEARCH=true
ELASTICSEARCH_URL=http://localhost:9200

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
